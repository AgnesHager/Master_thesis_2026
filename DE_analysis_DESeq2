# 1) READ METADATA AND COUNTS
meta_table <- read.csv("metadata_counts_genocode_10.09.csv", sep = ";", header = TRUE)
raw_counts <- read.table("Counts_genocode.txt", header = TRUE, comment.char = "#")

# 2) STRIP ENSEMBL VERSION; KEEP ONLY COUNT COLUMNS
raw_counts <- raw_counts %>%
  mutate(Geneid = sub("\\..*", "", Geneid)) %>%
  column_to_rownames("Geneid") %>%
  dplyr::select(6:ncol(.))

# 3) INTEGRITY CHECKS
stopifnot(ncol(raw_counts) == nrow(meta_table))
stopifnot(all(!is.na(meta_table$Sample)))
stopifnot(!any(duplicated(meta_table$Sample)))


# 4) SET SAMPLE NAMES AND ALIGN
colnames(raw_counts) <- meta_table$Sample
meta_table$Sample <- as.character(meta_table$Sample)
rownames(meta_table) <- meta_table$Sample
stopifnot(identical(colnames(raw_counts), rownames(meta_table)))
stopifnot(all(raw_counts >= 0))
stopifnot(all(raw_counts == round(raw_counts)))

# 5) REMOVE UNWANTED SAMPLES
# (mouse 600: sick, test fragment samples)
samples_to_remove <- c(
  "600_arc_S273","600_lc_S225","600_vmh_S177",
  "21_arc_test100ng_S286","21_arc__test65ng_S290","21_arc_test35ng_S289",
  "24_arc_test100ng_S288","24_arc_test65ng_S291","24_arc_test35ng_S292","24_arc_testFrag_S287"
)

meta_table_filt <- meta_table %>%
  dplyr::filter(!Sample %in% samples_to_remove)
stopifnot(!any(meta_table_filt$Sample %in% samples_to_remove))

raw_counts_filt <- raw_counts %>%
  dplyr::select(-all_of(samples_to_remove))
stopifnot(ncol(raw_counts_filt) == nrow(meta_table_filt))
stopifnot(identical(colnames(raw_counts_filt), meta_table_filt$Sample))

# 6) REMOVE ALL-ZERO GENES
nonzero <- rowSums(raw_counts_filt > 0) > 0
removed_n <- sum(!nonzero)
raw_counts_filt <- raw_counts_filt[nonzero, , drop = FALSE]
message("Removed ", removed_n, " all-zero genes.")

# 7) SET FACTOR LEVELS
meta_table_filt <- meta_table_filt %>%
  dplyr::mutate(
    Tissue   = factor(Tissue,   levels = c("ARC","LC","VMH")),
    Diet     = factor(Diet,     levels = c("CD","WD")),
    Genotype = factor(Genotype, levels = c("WT","KI")),
    Sex      = factor(Sex,      levels = c("F","M"))
  )

# 8) GENE ANNOTATION
ens_keys <- rownames(raw_counts_filt)

gene_annot <- AnnotationDbi::select(
  x       = org.Mm.eg.db,
  keys    = as.character(ens_keys),
  columns = c("ENSEMBL", "SYMBOL", "ENTREZID"),
  keytype = "ENSEMBL"
)

gene_annot <- gene_annot[, c("ENSEMBL", "SYMBOL", "ENTREZID")]
colnames(gene_annot) <- c("ensembl_gene_id", "external_gene_name", "entrezgene_id")

gene_annot <- gene_annot %>%
  mutate(
    ensembl_gene_id    = as.character(ensembl_gene_id),
    external_gene_name = as.character(external_gene_name),
    entrezgene_id      = as.character(entrezgene_id)
  )

gene_annot$mgi_symbol <- gene_annot$external_gene_name
gene_annot <- gene_annot[!duplicated(gene_annot$ensembl_gene_id), ]
rownames(gene_annot) <- gene_annot$ensembl_gene_id

message("Annotation rows: ", nrow(gene_annot))

# 9) CONTRAST FUNCTION
# Create output folders
dir.create("DEG_results", showWarnings = FALSE)
dir.create("DEG_results/by_contrast", showWarnings = FALSE)
dir.create("DEG_results/summaries", showWarnings = FALSE)

run_one_contrast <- function(counts_tissue, meta_tissue,
                             subset_filter,
                             compare_factor,   # "Genotype" or "Diet"
                             ref_level,        # "WT" or "CD"
                             coef_suffix,      # "Genotype_KI_vs_WT" or "Diet_WD_vs_CD"
                             outfile_prefix,
                             lfc_threshold = 0.263,
                             min_count = 10,
                             harmonize_names = FALSE) {

  # ---- 0) Subset metadata ----
  meta_sub <- meta_tissue %>% dplyr::filter(!! rlang::enquo(subset_filter))
  if (nrow(meta_sub) == 0) stop("No samples after filtering: ", deparse(substitute(subset_filter)))

  # ---- 1) Optional harmonization of sample IDs ----
  if (harmonize_names) {
    norm <- function(x) {
      x %>%
        gsub("\\s+", "", ., perl = TRUE) %>%
        gsub("-", "_", ., fixed = TRUE) %>%
        gsub("\\.bam$", "", ., perl = TRUE)
    }
    meta_sub$Sample         <- norm(meta_sub$Sample)
    colnames(counts_tissue) <- norm(colnames(counts_tissue))
  }

  # ---- 2) Integrity checks & subset counts ----
  if (anyDuplicated(meta_sub$Sample))
    stop("Duplicate Sample IDs in meta_sub: ", paste(unique(meta_sub$Sample[duplicated(meta_sub$Sample)]), collapse=", "))
  if (anyDuplicated(colnames(counts_tissue)))
    stop("Duplicate column names in counts_tissue; fix before proceeding.")
  if (!all(meta_sub$Sample %in% colnames(counts_tissue))) {
    missing <- setdiff(meta_sub$Sample, colnames(counts_tissue))
    stop("These metadata samples are missing in counts_tissue: ", paste(missing, collapse = ", "))
  }

  counts_sub <- counts_tissue[, meta_sub$Sample, drop = FALSE]
  stopifnot(identical(colnames(counts_sub), meta_sub$Sample))

  # ---- 3) Drop unused factor levels ----
  meta_sub <- meta_sub %>%
    dplyr::mutate(
      Tissue   = droplevels(Tissue),
      Sex      = droplevels(Sex),
      Diet     = droplevels(Diet),
      Genotype = droplevels(Genotype)
    )

  # ---- 4) Validate compare_factor ----
  group_tab <- table(meta_sub[[compare_factor]])
  if (length(group_tab) != 2L) {
    stop("Need exactly two levels in ", compare_factor, "; got: ", paste(names(group_tab), collapse=", "))
  }
  if (any(group_tab < 2)) {
    stop("One level of ", compare_factor, " has < 2 samples: ",
         paste(names(group_tab), group_tab, sep="=", collapse=", "))
  }

  # ---- 5) Relevel to reference ----
  meta_sub[[compare_factor]] <- stats::relevel(meta_sub[[compare_factor]], ref = ref_level)

  # ---- 6) Build DESeqDataSet ----
  dds <- DESeq2::DESeqDataSetFromMatrix(countData = counts_sub,
                                        colData   = meta_sub,
                                        design    = stats::reformulate(compare_factor))

  # ---- 7) Pre-filter per contrast using smallest group size ----
  filter_n <- min(group_tab)
  keep <- rowSums(DESeq2::counts(dds) >= min_count) >= filter_n
  dds  <- dds[keep, ]
  if (nrow(dds) < 100) warning("Very few genes after filtering (n=", nrow(dds), ").")

  # ---- 8) Fit and extract ----
  dds <- DESeq2::DESeq(dds)
  rn  <- DESeq2::resultsNames(dds)
  if (!(coef_suffix %in% rn)) {
    stop("Coefficient ", coef_suffix, " not found. Available: ", paste(rn, collapse=", "))
  }

  if (!requireNamespace("apeglm", quietly = TRUE)) {
    stop("Package 'apeglm' not installed. Install with BiocManager::install('apeglm') before running.")
  }

  res_unshrunk <- DESeq2::results(dds, name = coef_suffix, alpha = 0.05)
  res_shrunk   <- DESeq2::lfcShrink(dds, coef = coef_suffix, type = "apeglm")

  # ---- 9) Format & annotate ----
  df_un <- as.data.frame(res_unshrunk) %>%
    tibble::rownames_to_column("ensembl_gene_id")
  df_sh <- as.data.frame(res_shrunk) %>%
    tibble::rownames_to_column("ensembl_gene_id")

  if (exists("gene_annot", inherits = TRUE)) {
    df_un <- dplyr::left_join(df_un, gene_annot, by = "ensembl_gene_id")
    df_sh <- dplyr::left_join(df_sh, gene_annot, by = "ensembl_gene_id")
  }

  df_un <- df_un %>% dplyr::arrange(padj)
  df_sh <- df_sh %>% dplyr::arrange(padj)

  # ---- 10) Significant DEGs (padj < 0.05 AND |log2FC| >= 0.263) ----
  sig_sh <- df_sh %>%
    dplyr::filter(!is.na(padj), padj < 0.05, abs(log2FoldChange) >= lfc_threshold)

  # ---- 11) Write outputs ----
  readr::write_csv(df_un, file.path("DEG_results/by_contrast", paste0(outfile_prefix, "_stats_unshrunk.csv")))
  readr::write_csv(df_sh, file.path("DEG_results/by_contrast", paste0(outfile_prefix, "_stats_shrunk.csv")))
  readr::write_csv(sig_sh, file.path("DEG_results/by_contrast", paste0(outfile_prefix, "_sig_shrunk_lfc", lfc_threshold, ".csv")))

  list(
    dds        = dds,
    unshrunk   = df_un,
    shrunk     = df_sh,
    sig_ids_up = sig_sh %>% dplyr::filter(log2FoldChange > 0) %>% dplyr::pull(ensembl_gene_id),
    sig_ids_dn = sig_sh %>% dplyr::filter(log2FoldChange < 0) %>% dplyr::pull(ensembl_gene_id)
  )
}

# 10) RUN ALL CONTRASTS
tissues <- c("ARC","LC","VMH")
sexes   <- c("F","M")

run_all_contrasts_for_tissue <- function(tissue_id) {
  message("=== Tissue: ", tissue_id, " ===")
  meta_t   <- meta_table_filt %>% dplyr::filter(Tissue == tissue_id)
  counts_t <- raw_counts_filt[, meta_t$Sample, drop = FALSE]
  results_tissue <- list()

  for (sx in sexes) {
    message(" -- Sex: ", sx)
    meta_ts   <- meta_t %>% dplyr::filter(Sex == sx)
    counts_ts <- counts_t[, meta_ts$Sample, drop = FALSE]
    base_prefix <- paste0(tissue_id, "_", sx)

    # 1) KI vs WT within CD
    r_ki_cd <- run_one_contrast(
      counts_tissue = counts_ts,
      meta_tissue   = meta_ts,
      subset_filter = Diet == "CD",
      compare_factor= "Genotype",
      ref_level     = "WT",
      coef_suffix   = "Genotype_KI_vs_WT",
      outfile_prefix= paste0(base_prefix, "_KIvsWT_in_CD")
    )

    # 2) KI vs WT within WD
    r_ki_wd <- run_one_contrast(
      counts_tissue = counts_ts,
      meta_tissue   = meta_ts,
      subset_filter = Diet == "WD",
      compare_factor= "Genotype",
      ref_level     = "WT",
      coef_suffix   = "Genotype_KI_vs_WT",
      outfile_prefix= paste0(base_prefix, "_KIvsWT_in_WD")
    )

    # 3) WD vs CD within WT
    r_diet_wt <- run_one_contrast(
      counts_tissue = counts_ts,
      meta_tissue   = meta_ts,
      subset_filter = Genotype == "WT",
      compare_factor= "Diet",
      ref_level     = "CD",
      coef_suffix   = "Diet_WD_vs_CD",
      outfile_prefix= paste0(base_prefix, "_WDvsCD_in_WT")
    )

    # 4) WD vs CD within KI
    r_diet_ki <- run_one_contrast(
      counts_tissue = counts_ts,
      meta_tissue   = meta_ts,
      subset_filter = Genotype == "KI",
      compare_factor= "Diet",
      ref_level     = "CD",
      coef_suffix   = "Diet_WD_vs_CD",
      outfile_prefix= paste0(base_prefix, "_WDvsCD_in_KI")
    )

    results_tissue[[sx]] <- list(
      ki_cd   = r_ki_cd,
      ki_wd   = r_ki_wd,
      diet_wt = r_diet_wt,
      diet_ki = r_diet_ki
    )
  }
  results_tissue
}

# Run all tissues
all_results <- lapply(tissues, run_all_contrasts_for_tissue)
names(all_results) <- tissues
